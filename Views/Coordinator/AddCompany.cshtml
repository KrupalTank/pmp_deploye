@model PlacementMentorshipPortal.Models.CompanyWithImage

@{
    ViewData["Title"] = "Add Company";
}

<link rel="stylesheet" href="~/css/forms.css" />

<h2 class="page-title">🏢 Add Company</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success text-center">
        @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger text-center">
        @TempData["Error"]
    </div>
}

<div class="form-card">

    <form asp-controller="Coordinator" asp-action="AddCompanyMethod" enctype="multipart/form-data">

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label class="form-label">Coordinator</label>
            <input type="text" class="form-control" value="@User.Identity.Name" readonly />
        </div>

        <div class="mb-3">
            <label asp-for="Cname" class="form-label">Company Name</label>
            <input asp-for="Cname" class="form-control" />
            <span asp-validation-for="Cname" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="LogoPath" class="form-label">Company Logo</label>
            <input asp-for="LogoPath" type="file" class="form-control" />
            <span asp-validation-for="LogoPath" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary btn-submit">
            ➕ Create Company
        </button>
    </form>

    <a asp-controller="Coordinator" asp-action="Index" class="back-link text-primary">
        ← Back to List
    </a>
</div>
