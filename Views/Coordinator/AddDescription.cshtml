@model PlacementMentorshipPortal.Models.Description

@{
    ViewData["Title"] = "Add Description";
}

<link rel="stylesheet" href="~/css/forms.css" />

<h2 class="page-title">📝 Add Company Experience</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success text-center">
        @TempData["Success"]
    </div>
}

<div class="form-card">

    <form asp-action="AddDescriptionMethod">

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <!-- Coordinator -->
        <div class="mb-3">
            <label class="form-label">Coordinator</label>
            <input type="text" class="form-control" value="@User.Identity.Name" readonly />
        </div>

        <!-- Company Dropdown -->
        <div class="mb-3">
            <label asp-for="Cid" class="form-label">Company</label>
            <select asp-for="Cid" class="form-control" asp-items="ViewBag.Cid">
                <option value="">-- Select Company --</option>
            </select>
            <span asp-validation-for="Cid" class="text-danger"></span>
        </div>

        <!-- Experience Text -->
        <div class="mb-3">
            <label asp-for="Dtext" class="form-label">Experience</label>
            <textarea asp-for="Dtext" rows="5" class="form-control"></textarea>
            <span asp-validation-for="Dtext" class="text-danger"></span>
        </div>

        <!-- Submit Button -->
        <button type="submit" class="btn btn-primary btn-submit">
            ➕ Create Description
        </button>

    </form>

    <!-- Back Link -->
    <a asp-action="Index" class="back-link text-primary">
        ← Back to List
    </a>
</div>
