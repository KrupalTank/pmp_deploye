@model PlacementMentorshipPortal.Models.Studentsplaced

@{
    ViewData["Title"] = "Add Students";
}

<link rel="stylesheet" href="~/css/forms.css" />

<h2 class="page-title">🎓 Add Student</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success text-center">
        @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger text-center">
        @TempData["Error"]
    </div>
}

<div class="form-card">

    <form asp-action="AddStudentsMethod">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <!-- Coordinator -->
        <div class="mb-3">
            <label class="form-label">Coordinator</label>
            <input type="text" class="form-control" value="@User.Identity.Name" readonly />
        </div>

        <!-- Branch -->
        <div class="mb-3">
            <label asp-for="Bid" class="form-label">Branch</label>
            <select asp-for="Bid" class="form-control" asp-items="ViewBag.Bid">
                <option value="">-- Select Branch --</option>
            </select>
            <span asp-validation-for="Bid" class="text-danger"></span>
        </div>

        <!-- Year -->
        <div class="mb-3">
            <label asp-for="Yid" class="form-label">Year</label>
            <select asp-for="Yid" class="form-control" asp-items="ViewBag.Yid">
                <option value="">-- Select Year --</option>
            </select>
            <span asp-validation-for="Yid" class="text-danger"></span>
        </div>

        <!-- Company -->
        <div class="mb-3">
            <label asp-for="Cid" class="form-label">Company</label>
            <select asp-for="Cid" class="form-control" asp-items="ViewBag.Cid">
                <option value="">-- Select Company --</option>
            </select>
            <span asp-validation-for="Cid" class="text-danger"></span>
        </div>

        <!-- Student Name -->
        <div class="mb-3">
            <label asp-for="Sname" class="form-label">Student Name</label>
            <input asp-for="Sname" class="form-control" placeholder="Enter student name" />
            <span asp-validation-for="Sname" class="text-danger"></span>
        </div>

        <!-- Package -->
        <div class="mb-3">
            <label asp-for="Package" class="form-label">Package</label>
            <input asp-for="Package" class="form-control" placeholder="Enter package amount" />
            <span asp-validation-for="Package" class="text-danger"></span>
        </div>

        <!-- Contact / Email -->
        <div class="mb-3">
            <label asp-for="Contact" class="form-label">Email</label>
            <input asp-for="Contact" class="form-control" placeholder="Enter email" />
            <span asp-validation-for="Contact" class="text-danger"></span>
        </div>

        <!-- Submit -->
        <button type="submit" class="btn btn-primary btn-submit">
            ➕ Add Student
        </button>
    </form>

    <!-- Back -->
    <a asp-action="Index" class="back-link text-primary">
        ← Back to List
    </a>
</div>
