@model PlacementMentorshipPortal.Models.Resource

@{
    ViewData["Title"] = "Add Resources";
}

<link rel="stylesheet" href="~/css/forms.css" />

<h2 class="page-title">📚 Add Learning Resource</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success text-center">
        @TempData["Success"]
    </div>
}

<div class="form-card">

    <form asp-action="AddResourcesMethod">

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <!-- Coordinator -->
        <div class="mb-3">
            <label class="form-label">Coordinator</label>
            <input type="text" class="form-control" value="@User.Identity.Name" readonly />
        </div>

        <!-- Branch Dropdown -->
        <div class="mb-3">
            <label asp-for="Bid" class="form-label">Branch</label>
            <select asp-for="Bid" class="form-control" asp-items="ViewBag.BID">
                <option value="">-- Select Branch --</option>
            </select>
            <span asp-validation-for="Bid" class="text-danger"></span>
        </div>

        <!-- Resource Link -->
        <div class="mb-3">
            <label asp-for="Rlink" class="form-label">Resource Link</label>
            <input asp-for="Rlink" class="form-control" placeholder="Enter URL here" />
            <span asp-validation-for="Rlink" class="text-danger"></span>
        </div>

        <!-- Details -->
        <div class="mb-3">
            <label asp-for="Details" class="form-label">Details</label>
            <input asp-for="Details" class="form-control" placeholder="Short description of resource" />
            <span asp-validation-for="Details" class="text-danger"></span>
        </div>

        <!-- Submit -->
        <button type="submit" class="btn btn-primary btn-submit">
            ➕ Add Resource
        </button>

    </form>

    <!-- Back -->
    <a asp-action="Index" class="back-link text-primary">
        ← Back to List
    </a>
</div>
