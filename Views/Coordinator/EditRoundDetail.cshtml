@model PlacementMentorshipPortal.Models.Rounddetail

@{
    ViewData["Title"] = "Edit Round Detail";
}

<link rel="stylesheet" href="~/css/forms.css" />

<h2 class="page-title">✏️ Edit Round Detail</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success text-center">
        @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger text-center">
        @TempData["Error"]
    </div>
}

<div class="form-card">

    <form asp-action="EditRoundDetailMethod">

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <input type="hidden" asp-for="Id" />

        <!-- Coordinator -->
        <div class="mb-3">
            <label class="form-label">Coordinator</label>
            <input type="text" class="form-control" value="@User.Identity.Name" readonly />
        </div>

        <!-- Company Dropdown -->
        <div class="mb-3">
            <label asp-for="Cid" class="form-label">Company</label>
            <select asp-for="Cid" class="form-control" asp-items="ViewBag.Cid"></select>
            <span asp-validation-for="Cid" class="text-danger"></span>
        </div>

        <!-- Round Details Text -->
        <div class="mb-3">
            <label asp-for="Dtext" class="form-label">Round Description</label>
            <textarea asp-for="Dtext" rows="5" class="form-control"></textarea>
            <span asp-validation-for="Dtext" class="text-danger"></span>
        </div>

        <!-- Submit -->
        <button type="submit" class="btn btn-primary btn-submit">
            💾 Save Changes
        </button>
    </form>

    <!-- Back -->
    <a asp-action="Index" class="back-link text-primary">
        ← Back to List
    </a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
