@model PlacementMentorshipPortal.Models.Branch

@{
    ViewData["Title"] = "Add Branch";
}

<link rel="stylesheet" href="~/css/forms.css" />

<h2 class="page-title">🌿 Add Branch</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success text-center">
        @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger text-center">
        @TempData["Error"]
    </div>
}

<div class="form-card">

    <form asp-action="AddBranchMethod">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <!-- Branch Name -->
        <div class="mb-3">
            <label asp-for="Bname" class="form-label">Branch Name</label>
            <input asp-for="Bname" class="form-control" placeholder="Enter branch name" />
            <span asp-validation-for="Bname" class="text-danger"></span>
        </div>

        <!-- Submit -->
        <button type="submit" class="btn btn-primary btn-submit">
            ➕ Add Branch
        </button>
    </form>

    <!-- Back -->
    <a asp-action="Index" class="back-link text-primary">
        ← Back to List
    </a>
</div>
