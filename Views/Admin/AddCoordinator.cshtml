@model PlacementMentorshipPortal.Models.Coordinator

@{
    ViewData["Title"] = "Add Coordinator";
}

<link rel="stylesheet" href="~/css/forms.css" />

<h2 class="page-title">👨‍🏫 Add Coordinator</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success text-center">
        @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger text-center">
        @TempData["Error"]
    </div>
}

<div class="form-card">

    <form asp-action="AddCoordinatorMethod">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <!-- Branch -->
        <div class="mb-3">
            <label asp-for="Bid" class="form-label">Branch</label>
            <select asp-for="Bid" class="form-control" asp-items="ViewBag.BID">
                <option value="">-- Select Branch --</option>
            </select>
            <span asp-validation-for="Bid" class="text-danger"></span>
        </div>

        <!-- Year -->
        <div class="mb-3">
            <label asp-for="Yid" class="form-label">Year</label>
            <select asp-for="Yid" class="form-control" asp-items="ViewBag.YID">
                <option value="">-- Select Year --</option>
            </select>
            <span asp-validation-for="Yid" class="text-danger"></span>
        </div>

        <!-- Coordinator Name -->
        <div class="mb-3">
            <label asp-for="Tname" class="form-label">Coordinator Name</label>
            <input asp-for="Tname" class="form-control" placeholder="Enter coordinator name" />
            <span asp-validation-for="Tname" class="text-danger"></span>
        </div>

        <!-- Email -->
        <div class="mb-3">
            <label asp-for="Contact" class="form-label">Email</label>
            <input asp-for="Contact" class="form-control" placeholder="Enter email" />
            <span asp-validation-for="Contact" class="text-danger"></span>
        </div>

        <!-- User ID -->
        <div class="mb-3">
            <label asp-for="Uid" class="form-label">User Id</label>
            <input asp-for="Uid" class="form-control" placeholder="Enter user id" />
            <span asp-validation-for="Uid" class="text-danger"></span>
        </div>

        <!-- Password -->
        <div class="mb-3">
            <label asp-for="Pwd" class="form-label">Password</label>
            <input asp-for="Pwd" class="form-control" placeholder="Enter password" />
            <span asp-validation-for="Pwd" class="text-danger"></span>
        </div>

        <!-- Submit -->
        <button type="submit" class="btn btn-primary btn-submit">
            ➕ Add Coordinator
        </button>
    </form>

    <!-- Back -->
    <a asp-action="Index" class="back-link text-primary">
        ← Back to List
    </a>
</div>
