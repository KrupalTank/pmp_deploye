@model PlacementMentorshipPortal.Models.Year

@{
    ViewData["Title"] = "Edit Year";
}

<link rel="stylesheet" href="~/css/forms.css" />

<h2 class="page-title">📅 Edit Year</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success text-center">
        @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger text-center">
        @TempData["Error"]
    </div>
}

<div class="form-card">

    <form asp-action="EditYearMethod">

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <input type="hidden" asp-for="Yid" />

        <!-- Year -->
        <div class="mb-3">
            <label asp-for="Year1" class="form-label">Year</label>
            <input asp-for="Year1" class="form-control" />
            <span asp-validation-for="Year1" class="text-danger"></span>
        </div>

        <!-- Submit -->
        <button type="submit" class="btn btn-primary btn-submit">
            💾 Save Changes
        </button>
    </form>

    <!-- Back -->
    <a asp-controller="Admin" asp-action="Profile" class="back-link text-primary">
        ← Go To Profile
    </a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
