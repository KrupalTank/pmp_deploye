@model PlacementMentorshipPortal.Models.StudentCount

@{
    ViewData["Title"] = "Edit Student Intake";
}

<link rel="stylesheet" href="~/css/forms.css" />

<h2 class="page-title">✏️ Edit Student Intake</h2>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger text-center">
        @TempData["Error"]
    </div>
}

<div class="form-card">
    <form asp-action="EditStudentCountMethod">
        @* Essential for the Update logic to find the record *@
        <input type="hidden" asp-for="Id" />

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="Bid" class="form-label">Branch</label>
            <select asp-for="Bid" class="form-control" asp-items="ViewBag.Bid"></select>
            <span asp-validation-for="Bid" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Yid" class="form-label">Year</label>
            <select asp-for="Yid" class="form-control" asp-items="ViewBag.Yid"></select>
            <span asp-validation-for="Yid" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Count" class="form-label">Updated Eligible Students</label>
            <input asp-for="Count" type="number" class="form-control" />
            <span asp-validation-for="Count" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary btn-submit">
            💾 Update Intake
        </button>
    </form>

    <a asp-action="Profile" class="back-link text-primary">
        ← Back to Profile
    </a>
</div>