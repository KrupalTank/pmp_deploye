@model PlacementMentorshipPortal.Models.StudentCount

@{
    ViewData["Title"] = "Add Student Intake";
}

<link rel="stylesheet" href="~/css/forms.css" />

<h2 class="page-title">📈 Add Student Intake</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success text-center">
        @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger text-center">
        @TempData["Error"]
    </div>
}

<div class="form-card">
    <form asp-action="AddStudentCountMethod">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="Bid" class="form-label">Branch</label>
            <select asp-for="Bid" class="form-control" asp-items="ViewBag.Bid">
                <option value="">-- Select Branch --</option>
            </select>
            <span asp-validation-for="Bid" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Yid" class="form-label">Year</label>
            <select asp-for="Yid" class="form-control" asp-items="ViewBag.Yid">
                <option value="">-- Select Year --</option>
            </select>
            <span asp-validation-for="Yid" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Count" class="form-label">Total Eligible Students</label>
            <input asp-for="Count" type="number" class="form-control" placeholder="e.g. 60" />
            <span asp-validation-for="Count" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary btn-submit">
            ➕ Save Intake Count
        </button>
    </form>

    <a asp-action="Index" class="back-link text-primary">
        ← Back to Dashboard
    </a>
</div>