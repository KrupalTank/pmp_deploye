@model PlacementMentorshipPortal.Models.Coordinator

@{
    ViewData["Title"] = "Edit Coordinator";
}

<link rel="stylesheet" href="~/css/forms.css" />

<h2 class="page-title">🧑‍🏫 Edit Coordinator</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success text-center">
        @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger text-center">
        @TempData["Error"]
    </div>
}

<div class="form-card">

    <form asp-action="EditCoordinatorMethod">

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <input type="hidden" asp-for="Tid" />
        <input type="hidden" asp-for="Active" />

        <!-- Branch -->
        <div class="mb-3">
            <label asp-for="Bid" class="form-label">Branch</label>
            <select asp-for="Bid" class="form-control" asp-items="ViewBag.Bid"></select>
            <span asp-validation-for="Bid" class="text-danger"></span>
        </div>

        <!-- Year -->
        <div class="mb-3">
            <label asp-for="Yid" class="form-label">Year</label>
            <select asp-for="Yid" class="form-control" asp-items="ViewBag.Yid"></select>
            <span asp-validation-for="Yid" class="text-danger"></span>
        </div>

        <!-- Name -->
        <div class="mb-3">
            <label asp-for="Tname" class="form-label">Coordinator Name</label>
            <input asp-for="Tname" class="form-control" />
            <span asp-validation-for="Tname" class="text-danger"></span>
        </div>

        <!-- Contact -->
        <div class="mb-3">
            <label asp-for="Contact" class="form-label">Contact Email</label>
            <input asp-for="Contact" class="form-control" />
            <span asp-validation-for="Contact" class="text-danger"></span>
        </div>

        <!-- Username -->
        <div class="mb-3">
            <label asp-for="Uid" class="form-label">Username (UID)</label>
            <input asp-for="Uid" class="form-control" />
            <span asp-validation-for="Uid" class="text-danger"></span>
        </div>

        <!-- Password -->
        <div class="mb-3">
            <label asp-for="Pwd" class="form-label">Password</label>
            <input asp-for="Pwd" type="password" class="form-control" />
            <span asp-validation-for="Pwd" class="text-danger"></span>
        </div>

        <!-- Submit -->
        <button type="submit" class="btn btn-primary btn-submit">
            💾 Save Changes
        </button>
    </form>

    <!-- Back -->
    <a asp-action="Index" class="back-link text-primary">
        ← Back to List
    </a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
