@model PlacementMentorshipPortal.Models.AdminProfileViewModel

@{
    ViewData["Title"] = "Admin Profile";
}

<div class="container py-5">

    <!-- Header -->
    <div class="text-center mb-5">
        <h1 class="company-name">Admin Dashboard</h1>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    @if (Model == null)
    {
        <h3 class="text-muted text-center">No Data Found</h3>
    }
    else
    {
        <div class="accordion-section">

            <!-- Branches -->
            <div class="info-card" onclick="toggleCard(this)">
                <div class="info-header">
                    <h4>Branches Added</h4>
                    <span class="arrow">▼</span>
                </div>

                <div class="info-content">
                    @if (Model.branches != null && Model.branches.Any())
                    {
                        @foreach (var b in Model.branches)
                        {
                            <p class="student-line">
                                <strong>@b.Bname</strong>

                                <a asp-action="EditBranch" asp-route-id="@b.Bid"
                                   class="btn btn-sm btn-primary ms-2">Update</a>
                            </p>
                        }
                    }
                    else
                    {
                        <p class="text-muted">No branches found.</p>
                    }
                </div>
            </div>

            <!-- Years -->
            <div class="info-card" onclick="toggleCard(this)">
                <div class="info-header">
                    <h4>Years Added</h4>
                    <span class="arrow">▼</span>
                </div>

                <div class="info-content">
                    @if (Model.years != null && Model.years.Any())
                    {
                        @foreach (var y in Model.years)
                        {
                            <p class="student-line">
                                <strong>@y.Year1</strong>

                                <a asp-action="EditYear" asp-route-id="@y.Yid"
                                   class="btn btn-sm btn-primary ms-2">Update</a>
                            </p>
                        }
                    }
                    else
                    {
                        <p class="text-muted">No years found.</p>
                    }
                </div>
            </div>

            <!-- Coordinators -->
            <div class="info-card" onclick="toggleCard(this)">
                <div class="info-header">
                    <h4>Active Coordinators</h4>
                    <span class="arrow">▼</span>
                </div>

                <div class="info-content">
                    @if (Model.coordinators != null && Model.coordinators.Any())
                    {
                        @foreach (var c in Model.coordinators)
                        {
                            <p class="student-line">
                                <strong>@c.Tname</strong>
                                (@c.BidNavigation.Bname)
                                | 📧 <a href="mailto:@c.Contact">@c.Contact</a>

                                <a asp-action="EditCoordinator" asp-route-id="@c.Tid"
                                   class="btn btn-sm btn-primary ms-2">Update</a>
                            </p>
                        }
                    }
                    else
                    {
                        <p class="text-muted">No active coordinators found.</p>
                    }
                </div>
            </div>

            <div class="info-card" id="intakeCard">
                <div class="info-header" onclick="toggleCard(document.getElementById('intakeCard'))">
                    <h4>Branch Intake Summary</h4>
                    <span class="arrow">▼</span>
                </div>

                <div class="info-content">
                    <div class="mb-3 d-flex align-items-center gap-2">
                        <label class="small fw-bold">Filter Year:</label>
                        <select id="intakeYearFilter" class="form-select form-select-sm" style="width: auto;">
                            @foreach (var y in Model.years)
                            {
                                <option value="@y.Year1" selected="@(y.Year1 == DateTime.Now.Year)">@y.Year1</option>
                            }
                        </select>
                    </div>

                    <div id="intakeContainer">
                        @if (Model.studentCounts != null && Model.studentCounts.Any())
                        {
                            @foreach (var sc in Model.studentCounts)
                            {
                                <div class="student-line d-flex justify-content-between align-items-center">
                                    <span><strong>@sc.BranchNavigation.Bname</strong>: @sc.Count Students</span>
                                    <a asp-action="EditStudentCount" asp-route-id="@sc.Id" class="btn btn-sm btn-primary">Update</a>
                                </div>
                            }
                        }
                        else
                        {
                            <p class="text-muted p-2">No intake data found for this year.</p>
                        }
                    </div>

                    <div class="mt-3">
                        <a asp-action="AddStudentCount" class="btn btn-sm btn-outline-primary">+ Add New Intake</a>
                    </div>
                </div>
            </div>

        </div>

        <!-- Back Button -->
        <div class="text-center mt-4">
            <a asp-action="Index" class="btn btn-primary px-4 py-2 rounded-3">
                ← Back to Dashboard
            </a>
        </div>
    }
</div>

<style>
    /* ===== Header ===== */
    .company-name {
        color: #1e293b;
        font-weight: 700;
        letter-spacing: 1px;
    }

    /* ===== Info Cards (same as coordinator) ===== */
    .info-card {
        background: linear-gradient(135deg, #ffffff, #f5f7ff);
        border: 1px solid rgba(99, 102, 241, 0.25);
        border-radius: 18px;
        padding: 18px 22px;
        margin-bottom: 18px;
        cursor: pointer;
        transition: all 0.35s ease;
        box-shadow: 0 8px 22px rgba(0, 0, 0, 0.08);
    }

        .info-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 30px rgba(0,0,0,0.12), 0 0 18px rgba(99,102,241,0.25), 0 0 24px rgba(168,85,247,0.18);
        }

    .info-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        color: #312e81;
    }

        .info-header h4 {
            font-weight: 600;
            margin: 0;
        }

    .info-content {
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.4s ease, margin-top 0.3s ease;
        color: #334155;
    }

    .info-card.active .info-content {
        max-height: 900px;
        margin-top: 14px;
    }

    .arrow {
        transition: transform 0.3s ease;
        color: #6366f1;
        font-size: 18px;
    }

    .info-card.active .arrow {
        transform: rotate(180deg);
    }

    /* ===== Record line ===== */
    .student-line {
        background: linear-gradient(135deg, #eef2ff, #fdf4ff);
        border: 1px solid rgba(168, 85, 247, 0.18);
        padding: 10px 14px;
        border-radius: 10px;
        margin-bottom: 10px;
        font-size: 0.95rem;
        color: #1e293b;
        transition: 0.25s ease;
    }

        .student-line:hover {
            background: linear-gradient(135deg, #e0e7ff, #fce7f3);
            transform: translateX(4px);
        }

        .student-line a {
            color: #4f46e5;
            font-weight: 500;
            text-decoration: none;
        }

            .student-line a:hover {
                text-decoration: underline;
                color: #7c3aed;
            }

    /* Update button */
    .info-card .btn-primary {
        background: linear-gradient(135deg, #4f46e5, #7c3aed);
        border: none;
        color: #fff;
        font-weight: 500;
        border-radius: 8px;
        padding: 4px 10px;
        transition: 0.25s ease;
    }

        .info-card .btn-primary:hover {
            background: linear-gradient(135deg, #4338ca, #6d28d9);
            box-shadow: 0 4px 12px rgba(79,70,229,0.35);
        }
</style>

<script>
    function toggleCard(card) {
        card.classList.toggle("active");
    }

        document.getElementById('intakeYearFilter').addEventListener('change', async function () {
        const year = this.value;
        const container = document.getElementById('intakeContainer');

        try {
            const response = await fetch(`/admin/getintakebyyear/${year}`);
            const data = await response.json();

            if (data.length > 0) {
                container.innerHTML = data.map(sc => `
                    <div class="student-line d-flex justify-content-between align-items-center">
                        <span><strong>${sc.branchName}</strong>: ${sc.count} Students</span>
                        <a href="/admin/editstudentcount/${sc.id}" class="btn btn-sm btn-primary">Update</a>
                    </div>
                `).join('');
            } else {
                container.innerHTML = '<p class="text-muted p-2">No intake data found for this year.</p>';
            }
        } catch (error) {
            console.error('Error fetching intake data:', error);
        }
    });
</script>
