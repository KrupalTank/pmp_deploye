@model string

@{
    ViewData["Title"] = "Verify OTP";
}

<link rel="stylesheet" href="~/css/forms.css" />

<h2 class="page-title">🔐 Verify OTP</h2>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger text-center">
        @TempData["Error"]
    </div>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success text-center">
        @TempData["Success"]
    </div>
}

<div class="form-card">

    <p class="text-muted text-center mb-3">
        Enter the <strong>6-digit verification code</strong> sent to your email.
    </p>

    <form asp-action="VerifyOtp" method="post">

        <div class="mb-3">
            <label class="form-label">One-Time Password</label>
            <input name="userOtp"
                   class="form-control text-center"
                   placeholder="123456"
                   maxlength="6"
                   required
                   style="letter-spacing: 6px; font-size: 1.4rem;" />
        </div>

        <button type="submit" class="btn btn-primary btn-submit">
            Verify Code
        </button>
    </form>

    <a asp-controller="Authentication" asp-action="ForgetPassword"
       class="back-link text-primary">
        Resend verification email?
    </a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
